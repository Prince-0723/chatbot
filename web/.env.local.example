# If you use the separate backend (`back/`) set this and you DON'T need GROQ_API_KEY here:
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Only needed if you use Next.js API routes under `web/src/app/api/*`:
# GROQ_API_KEY=your_key_here
# Optional: where to store chat JSON (defaults to ../chats)
# CHAT_STORE_DIR=C:\full\path\to\chats
